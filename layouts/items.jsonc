                "mistHeart",
                "giantKin",
                "goMode"
              ],
              [
                "leniKey",
                "homeKey",
                "soldierKey",
                "bastKey",
                "antiqKey",
                "fangKey",
                "brightKey",
                "rotund"
              ],
              [
                "lockawayKey",
                "denKey",
                "ironKey",
                "forgorKey",
                "passKey",
                "aldiaKey",
                "embedKey",
                "sancKey"
              ],
              [
                "hevIronKey",
                "flower",
                "dragClaw",
                "dragStone",
                "scepter",
                "garyKey",
                "eye"
              ],
              [
                "rosa",
                "betwixtMan",
                "heideMan",
                "bastilleMan",
                "straide",
                "gulchMan",
                "mantarkMan"
              ],
              [
